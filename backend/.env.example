# ── Required ──────────────────────────────────────────────────
# Get a free key from https://console.groq.com
GROQ_API_KEY=

# ── Recommended ───────────────────────────────────────────────
# Raises GitHub API rate limit from 60/hr to 5000/hr
# Create at https://github.com/settings/tokens (read-only, public repos)
GITHUB_TOKEN=

# ── Optional overrides ────────────────────────────────────────
GROQ_MODEL=llama-3.3-70b-versatile

# Secret for verifying GitHub webhook payloads (any random string)
GITHUB_WEBHOOK_SECRET=changeme-webhook-secret

# Set to true in production to require X-API-Key header on all requests
ENABLE_AUTH=false
API_KEY=changeme-api-key

# Sentry DSN for error tracking (https://sentry.io)
SENTRY_DSN=

# Rate limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=30
